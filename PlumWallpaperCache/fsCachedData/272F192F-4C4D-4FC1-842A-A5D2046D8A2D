<script>
(function () {
  var categoriesBtn = document.getElementById('dhCategoriesBtn');
  var categoriesMenu = document.getElementById('dhCategoriesMenu');

  var resolutionBtn = document.getElementById('dhResolutionBtn');
  var resolutionMenu = document.getElementById('dhResolutionMenu');

  var mobileOpen = document.getElementById('dhMobileOpen');
  var mobileClose = document.getElementById('dhMobileClose');
  var mobileMenu = document.getElementById('dhMobileMenu');
  var lastFocused = null;

  function openMenu(btn, menu) {
    if (!btn || !menu) return;
    menu.style.display = 'block';
    btn.setAttribute('aria-expanded', 'true');
  }

  function closeMenu(btn, menu) {
    if (!btn || !menu) return;
    menu.style.display = 'none';
    btn.setAttribute('aria-expanded', 'false');
  }

  function closeAllDesktopMenus() {
    closeMenu(categoriesBtn, categoriesMenu);
    closeMenu(resolutionBtn, resolutionMenu);
  }

  function toggleMenu(e, btn, menu, otherBtn, otherMenu) {
    e.preventDefault();
    var isOpen = menu && menu.style.display === 'block';
    closeMenu(otherBtn, otherMenu);

    if (isOpen) {
      closeMenu(btn, menu);
    } else {
      openMenu(btn, menu);
    }
  }

  function openMobileMenu() {
    if (!mobileMenu || !mobileOpen) return;
    lastFocused = document.activeElement;
    mobileMenu.style.display = 'block';
    mobileMenu.setAttribute('aria-hidden', 'false');
    mobileOpen.setAttribute('aria-expanded', 'true');
    document.documentElement.style.overflow = 'hidden';
    document.body.style.overflow = 'hidden';
    if (mobileClose) mobileClose.focus();
  }

  function closeMobileMenu() {
    if (!mobileMenu || !mobileOpen) return;
    mobileMenu.style.display = 'none';
    mobileMenu.setAttribute('aria-hidden', 'true');
    mobileOpen.setAttribute('aria-expanded', 'false');
    document.documentElement.style.overflow = '';
    document.body.style.overflow = '';
    if (lastFocused) lastFocused.focus();
  }

  if (categoriesBtn) {
    categoriesBtn.addEventListener('click', function (e) {
      toggleMenu(e, categoriesBtn, categoriesMenu, resolutionBtn, resolutionMenu);
    });
  }

  if (resolutionBtn) {
    resolutionBtn.addEventListener('click', function (e) {
      toggleMenu(e, resolutionBtn, resolutionMenu, categoriesBtn, categoriesMenu);
    });
  }

  document.addEventListener('click', function (e) {
    var insideCategories = categoriesBtn && categoriesMenu &&
      (categoriesBtn.contains(e.target) || categoriesMenu.contains(e.target));

    var insideResolution = resolutionBtn && resolutionMenu &&
      (resolutionBtn.contains(e.target) || resolutionMenu.contains(e.target));

    if (!insideCategories && !insideResolution) {
      closeAllDesktopMenus();
    }

    if (mobileMenu && e.target === mobileMenu) {
      closeMobileMenu();
    }
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      closeAllDesktopMenus();
      closeMobileMenu();
    }
  });

  if (mobileOpen) {
    mobileOpen.addEventListener('click', openMobileMenu);
  }

  if (mobileClose) {
    mobileClose.addEventListener('click', closeMobileMenu);
  }

  if (mobileMenu) {
    var mobileLinks = mobileMenu.querySelectorAll('a');
    mobileLinks.forEach(function (link) {
      link.addEventListener('click', function () {
        closeMobileMenu();
      });
    });

    var accButtons = mobileMenu.querySelectorAll('.dh-mobile-acc-btn');
    accButtons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var targetId = btn.getAttribute('data-target');
        var panel = document.getElementById(targetId);
        if (!panel) return;
        panel.classList.toggle('is-open');
      });
    });
  }
})();
</script>

