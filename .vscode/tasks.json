{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "xcodebuild: Debug PlumWallPaper",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-project",
        "${workspaceFolder}/PlumWallPaper.xcodeproj",
        "-scheme",
        "PlumWallPaper",
        "-configuration",
        "Debug",
        "-derivedDataPath",
        "${workspaceFolder}/Build/DerivedData",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "xcodebuild: Release PlumWallPaper",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-project",
        "${workspaceFolder}/PlumWallPaper.xcodeproj",
        "-scheme",
        "PlumWallPaper",
        "-configuration",
        "Release",
        "-derivedDataPath",
        "${workspaceFolder}/Build/DerivedData",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
