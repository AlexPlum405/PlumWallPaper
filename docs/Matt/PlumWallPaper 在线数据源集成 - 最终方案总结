  八、关键技术点

  1. 模型命名冲突解决

  - WaifuX Wallpaper → RemoteWallpaper
  - WaifuX MediaItem → 保持不变
  - PlumWallPaper Wallpaper → 保持不变

  2. 数据源权重算法

  func calculateScore(_ item: MediaItem, sourceWeight: Double) -> Double {
      let normalizedViews = min(item.views / 100_000.0, 1.0)
      let normalizedFavorites = min(item.favorites / 10_000.0, 1.0)
      let resolutionScore = getResolutionScore(item.resolution)
      let recencyScore = getRecencyScore(item.publishDate)

      let qualityScore = (normalizedViews * 0.3)
                       + (normalizedFavorites * 0.3)
                       + (resolutionScore * 0.25)
                       + (recencyScore * 0.15)

      return qualityScore * sourceWeight
  }

  3. 多样性保证

  func applyDiversityRules(_ candidates: [(MediaItem, Double)], count: Int) -> [MediaItem] {
      var result: [MediaItem] = []
      var usedAuthors = Set<String>()
      var tagCounts: [String: Int] = [:]

      for (item, _) in candidates {
          guard result.count < count else { break }
          if usedAuthors.contains(item.author) { continue }
          if let tag = item.tags.first, tagCounts[tag, default: 0] >= 2 { continue }

          result.append(item)
          usedAuthors.insert(item.author)
          if let tag = item.tags.first { tagCounts[tag, default: 0] += 1 }
      }
      return result
  }

